{
  "name": "@openapi-typescript-infra/external-id",
  "version": "0.0.0",
  "description": "A minimal dependency utility to manage prefixed short UUIDs for your organization",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./cli": {
      "types": "./build/cli.d.ts",
      "default": "./build/cli.js"
    },
    "./expander": {
      "types": "./build/expander.d.ts",
      "default": "./build/expander.js"
    }
  },
  "author": "Developers <developers@pyralis.com>",
  "license": "MIT",
  "packageManager": "yarn@3.8.7",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "yarn dlx rimraf ./dist",
    "lint": "eslint .",
    "test": "vitest",
    "postinstall": "cpconfig"
  },
  "files": [
    "build",
    "README.md"
  ],
  "keywords": [
    "typescript",
    "uuid",
    "external-id"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openapi-typescript-infra/external-id.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "publishCmd": "yarn dlx pinst --disable"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "config": {
    "cpconfig": "@openapi-typescript-infra/cpconfig"
  },
  "prettier": {
    "bracketSpacing": true,
    "bracketSameLine": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "overrides": [
      {
        "files": "*.js",
        "options": {
          "parser": "babel"
        }
      }
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@openapi-typescript-infra/cpconfig": "^1.1.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "cpconfig": "^1.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "any-base": "^1.1.0"
  }
}
